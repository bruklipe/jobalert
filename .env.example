# Fill these in if you want the workflow to read Indeed job alerts by IMAP.
# You can use a plaintext password env var, but the safer path is to store the
# password in macOS Keychain and only keep the service name here.
INDEED_IMAP_HOST=imap.gmail.com
INDEED_IMAP_USER=your_email@example.com
INDEED_IMAP_PASSWORD_KEYCHAIN_SERVICE=indeed-job-triage-imap
# Optional fallback if you do not want to use Keychain:
# INDEED_IMAP_PASSWORD=your_imap_password
